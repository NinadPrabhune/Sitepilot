              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"department_id\": 1 }"
            },
            "url": {
              "raw": "{{base_url}}/api/getdDesignation",
              "host": ["{{base_url}}"],
              "path": ["api", "getdDesignation"]
            }
          }
        }
      ]
    }
  ]
}
