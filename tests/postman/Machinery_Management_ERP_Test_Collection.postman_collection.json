									"    pm.expect(responseJson).to.have.property('token');",
									"    pm.collectionVariables.set('auth_token', responseJson.token);",
									"    pm.collectionVariables.set('token_expires', Date.now() + 3600000);",
									"});"
								]
							}
						}
					],
