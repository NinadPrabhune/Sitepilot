        "summary": "List all payments",
        "description": "Returns a list of all payments with optional filtering by supplier_id, site_id, and workspace_id.",
        "operationId": "listPayments",
        "parameters": [
          {"name": "supplier_id", "in": "query", "description": "Filter by supplier ID", "schema": {"type": "integer"}},
          {"name": "site_id", "in": "query", "description": "Filter by site ID", "schema": {"type": "integer"}},
          {"name": "workspace_id", "in": "query", "description": "Filter by workspace ID", "schema": {"type": "integer"}}
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Payments retrieved successfully",
                  "data": [
                    {
                      "id": 1,
                      "payment_number": "PAY-0001",
                      "created_by": 1,
                      "workspace_id": 1,
                      "supplier_id": 1,
                      "site_id": 1,
                      "payment_date": "2026-03-24",
                      "amount": 5000.00,
                      "payment_type": "against_invoice",
                      "mode": "bank_transfer",
                      "reference_number": "REF-001",
                      "notes": "Payment for invoice",
                      "purchase_invoice_id": 1,
                      "purchase_order_id": null,
                      "ac_payment_status": "approved",
                      "rejection_reason": null,
                      "payment_proff_file": null,
                      "created_at": "2026-03-24T10:00:00Z",
                      "updated_at": "2026-03-24T10:00:00Z",
                      "supplier": {"id": 1, "name": "ABC Suppliers"},
                      "site": {"id": 1, "name": "Project Site A"}
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "example": {"success": false, "message": "Unauthenticated", "data": null}
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "example": {"success": false, "message": "Failed to fetch payments", "data": null}
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Payments"],
        "summary": "Create a new payment",
        "description": "Creates a new payment record. Supports payment types: against_invoice, advance, and mixed.\n\n--- MOBILE DEVELOPER FORM-DATA GUIDE ---\n\nALWAYS REQUIRED (include in every request):\n- created_by (integer): User ID who created the payment\n- workspace_id (integer): Workspace ID\n- supplier_id (integer): Supplier ID - must exist in suppliers table\n- site_id (integer): Site/Project ID - must exist in projects table\n- payment_date (string): Payment date in YYYY-MM-DD format\n- amount (number): Payment amount - must be greater than 0\n- payment_type (string): Type - enum: against_invoice, advance, mixed\n\nOPTIONAL FIELDS:\n- mode (string): Payment mode - bank_transfer, cash, check, online\n- reference_number (string): Reference number\n- notes (string): Additional notes\n- purchase_invoice_id (integer): Purchase Invoice ID\n- purchase_order_id (integer): REQUIRED if payment_type=advance\n- ac_payment_status (string): pending, approved, rejected\n- rejection_reason (string): REQUIRED if ac_payment_status=rejected\n- payment_proff_file (file): Payment proof file upload\n- allocations (string): JSON array - REQUIRED if payment_type=against_invoice or mixed\n  Format: [{\"invoice_id\":1,\"order_id\":1,\"amount\":2500.00}]\n  Each item: invoice_id (required), order_id (optional), amount (required > 0)",
        "operationId": "createPayment",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "created_by": {
                    "type": "integer",
                    "description": "User ID who created the payment (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "workspace_id": {
                    "type": "integer",
                    "description": "Workspace ID (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "supplier_id": {
                    "type": "integer",
                    "description": "Supplier ID - must exist in suppliers table (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "site_id": {
                    "type": "integer",
                    "description": "Site/Project ID - must exist in projects table (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "payment_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Payment date in YYYY-MM-DD format (ALWAYS REQUIRED)",
                    "example": "2026-03-24"
                  },
                  "amount": {
                    "type": "number",
                    "description": "Payment amount - must be greater than 0 (ALWAYS REQUIRED)",
                    "example": 5000.00
                  },
                  "payment_type": {
                    "type": "string",
                    "enum": ["against_invoice", "advance", "mixed"],
                    "description": "Type of payment - against_invoice: payment for specific invoices, advance: payment before invoice, mixed: combination (ALWAYS REQUIRED)",
                    "example": "against_invoice"
                  },
                  "mode": {
                    "type": "string",
                    "description": "Payment mode: bank_transfer, cash, check, online (OPTIONAL)",
                    "example": "bank_transfer"
                  },
                  "reference_number": {
                    "type": "string",
                    "description": "Reference number for the payment (OPTIONAL)",
                    "example": "REF-001"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Additional notes or description (OPTIONAL)",
                    "example": "Payment for invoice"
                  },
                  "purchase_invoice_id": {
                    "type": "integer",
                    "description": "Purchase Invoice ID - links payment to a specific invoice (OPTIONAL)",
                    "example": 1
                  },
                  "purchase_order_id": {
                    "type": "integer",
                    "description": "Purchase Order ID - REQUIRED if payment_type=advance, otherwise optional",
                    "example": 1
                  },
                  "ac_payment_status": {
                    "type": "string",
                    "enum": ["pending", "approved", "rejected"],
                    "description": "Account payment status: pending (default), approved, rejected (OPTIONAL)",
                    "example": "approved"
                  },
                  "rejection_reason": {
                    "type": "string",
                    "description": "Reason for rejection - REQUIRED if ac_payment_status=rejected",
                    "example": "Incorrect details"
                  },
                  "payment_proff_file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Payment proof file upload - image or document file (OPTIONAL)"
                  },
                  "allocations": {
                    "type": "string",
                    "description": "JSON array of allocations - REQUIRED if payment_type=against_invoice or mixed. Format: [{\"invoice_id\":1,\"order_id\":1,\"amount\":2500.00}]. Each allocation needs invoice_id and amount (>0), order_id is optional.",
                    "example": "[{\"invoice_id\":1,\"order_id\":1,\"amount\":2500.00}]"
                  }
                },
                "required": ["created_by", "workspace_id", "supplier_id", "site_id", "payment_date", "amount", "payment_type"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Payment created successfully",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "message": "Payment created successfully",
                  "data": {
                    "id": 1,
                    "payment_number": "PAY-0001",
                    "created_by": 1,
                    "workspace_id": 1,
                    "supplier_id": 1,
                    "site_id": 1,
                    "payment_date": "2026-03-24",
                    "amount": 5000.00,
                    "payment_type": "against_invoice",
                    "mode": "bank_transfer",
                    "reference_number": "REF-001",
                    "notes": "Payment for invoice",
                    "purchase_invoice_id": null,
                    "purchase_order_id": null,
                    "ac_payment_status": "pending",
                    "rejection_reason": null,
                    "payment_proff_file": null,
                    "created_at": "2026-03-24T10:00:00Z",
                    "updated_at": "2026-03-24T10:00:00Z",
                    "supplier": {"id": 1, "name": "ABC Suppliers"},
                    "site": {"id": 1, "name": "Project Site A"},
                    "allocations": [
                      {"id": 1, "payment_module_id": 1, "purchase_invoice_id": 1, "purchase_order_id": 1, "allocated_amount": 5000.00}
                    ]
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "example": {"success": false, "message": "Unauthenticated", "data": null}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "example": {
                  "success": false,
                  "message": "The supplier_id field is required.",
                  "data": null,
                  "errors": {
                    "supplier_id": ["The supplier_id field is required."],
                    "payment_type": ["The payment_type field is required."],
                    "amount": ["The amount field is required."]
                  }
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "example": {"success": false, "message": "Failed to create payment", "data": null}
              }
            }
          }
        }
      }
    },
