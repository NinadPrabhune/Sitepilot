{
  "id": "user-api-controller-collection",
  "name": "UserApiController",
  "description": "User Management API Collection",
  "items": [
    {
      "id": "users-list",
      "name": "List Users",
      "description": "GET /api/users - List all users with optional filters",
      "method": "GET",
      "url": "{{base_url}}/api/users",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "application/json"
      },
      "params": {
        "name": {"type": "text", "required": false, "description": "Filter by name"},
        "email": {"type": "text", "required": false, "description": "Filter by email"},
        "role": {"type": "text", "required": false, "description": "Filter by role ID"},
        "workspace_id": {"type": "text", "required": false, "description": "Filter by workspace"},
        "page": {"type": "text", "required": false, "description": "Page number"},
        "per_page": {"type": "text", "required": false, "description": "Items per page"}
      },
      "body": null,
      "response": {
        "success": {"status": true, "message": "Users retrieved successfully", "data": {"users": [], "pagination": {}}},
        "error": {"status": false, "message": "Permission denied", "data": {}}
      }
    },
    {
      "id": "users-create-data",
      "name": "Get Create Data",
