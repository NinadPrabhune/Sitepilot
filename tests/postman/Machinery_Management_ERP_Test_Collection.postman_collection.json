{
	"info": {
		"_postman_id": "machinery-management-erp-test",
		"name": "Machinery Management ERP Test Collection",
		"description": "Complete API test collection for Machinery Management ERP flow including DPR creation, payment requests, and validation",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{auth_token}}",
				"type": "string"
			}
		]
	},
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Auto-refresh token if expired",
					"if (!pm.collectionVariables.get('auth_token') || Date.now() > pm.collectionVariables.get('token_expires')) {",
					"    pm.sendRequest({",
					"        url: pm.collectionVariables.get('base_url') + '/login',",
					"        method: 'POST',",
					"        header: {",
					"            'Content-Type': 'application/json',",
					"            'Accept': 'application/json'",
					"        },",
					"        body: {",
					"            mode: 'raw',",
					"            raw: JSON.stringify({",
					"                email: pm.collectionVariables.get('test_email'),",
					"                password: pm.collectionVariables.get('test_password')",
					"            })",
					"        }",
					"    }, function (err, res) {",
					"        if (res && res.code === 200) {",
					"            const response = res.json();",
					"            pm.collectionVariables.set('auth_token', response.token);",
					"            pm.collectionVariables.set('token_expires', Date.now() + 3600000); // 1 hour",
					"        }",
					"    });",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Global response validation",
					"pm.test('Response has valid status', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 204, 422]);",
					"});",
					"",
					"pm.test('Response has valid JSON', function () {",
					"    try {",
					"        const responseJson = pm.response.json();",
					"        pm.expect(responseJson).to.be.an('object');",
					"    } catch (e) {",
					"        // Ignore if not JSON",
					"    }",
					"});"
				]
			}
		}
	],
