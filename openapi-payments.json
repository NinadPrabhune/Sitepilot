      "put": {
        "tags": ["Payments"],
        "summary": "Update a payment",
        "description": "Updates an existing payment. Note: Existing allocations are deleted and recreated.\n\n--- MOBILE DEVELOPER FORM-DATA GUIDE ---\n\nALWAYS REQUIRED (include in every request):\n- created_by (integer): User ID who created the payment\n- workspace_id (integer): Workspace ID\n- supplier_id (integer): Supplier ID - must exist in suppliers table\n- site_id (integer): Site/Project ID - must exist in projects table\n- payment_date (string): Payment date in YYYY-MM-DD format\n- amount (number): Payment amount - must be greater than 0\n- payment_type (string): Type - enum: against_invoice, advance, mixed\n\nOPTIONAL FIELDS:\n- mode (string): Payment mode - bank_transfer, cash, check, online\n- reference_number (string): Reference number\n- notes (string): Additional notes\n- purchase_invoice_id (integer): Purchase Invoice ID\n- purchase_order_id (integer): REQUIRED if payment_type=advance\n- ac_payment_status (string): pending, approved, rejected\n- rejection_reason (string): REQUIRED if ac_payment_status=rejected\n- payment_proff_file (file): Payment proof file upload\n- allocations (string): JSON array - REQUIRED if payment_type=against_invoice or mixed\n  Format: [{\"invoice_id\":1,\"order_id\":1,\"amount\":2500.00}]",
        "operationId": "updatePayment",
        "parameters": [
          {"name": "id", "in": "path", "required": true, "description": "Payment ID to update", "schema": {"type": "integer", "example": 1}}
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "created_by": {
                    "type": "integer",
                    "description": "User ID (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "workspace_id": {
                    "type": "integer",
                    "description": "Workspace ID (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "supplier_id": {
                    "type": "integer",
                    "description": "Supplier ID - must exist in suppliers table (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "site_id": {
                    "type": "integer",
                    "description": "Site/Project ID - must exist in projects table (ALWAYS REQUIRED)",
                    "example": 1
                  },
                  "payment_date": {
                    "type": "string",
                    "format": "date",
                    "description": "Payment date in YYYY-MM-DD format (ALWAYS REQUIRED)",
                    "example": "2026-03-24"
