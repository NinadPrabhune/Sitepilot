                    "description": "Type of payment (ALWAYS REQUIRED)",
                    "example": "against_invoice"
                  },
                  "mode": {
                    "type": "string",
                    "description": "Payment mode: bank_transfer, cash, check, online (OPTIONAL)",
                    "example": "bank_transfer"
                  },
                  "reference_number": {
                    "type": "string",
                    "description": "Reference number (OPTIONAL)",
                    "example": "REF-002"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Additional notes (OPTIONAL)",
                    "example": "Updated payment"
                  },
                  "purchase_invoice_id": {
                    "type": "integer",
                    "description": "Purchase Invoice ID (OPTIONAL)",
                    "example": 1
                  },
                  "purchase_order_id": {
                    "type": "integer",
                    "description": "Purchase Order ID - REQUIRED if payment_type=advance (OPTIONAL)",
                    "example": 1
                  },
                  "ac_payment_status": {
                    "type": "string",
                    "enum": ["pending", "approved", "rejected"],
                    "description": "Account payment status (OPTIONAL)",
                    "example": "approved"
                  },
