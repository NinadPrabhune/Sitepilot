{
  "info": {
    "name": "Employee API Collection",
    "_postman_id": "c4a8b2d2-2f6b-4a7a-bb3e-employee-api",
    "description": "Employee API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://your-domain.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_BEARER_TOKEN",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Employees",
      "item": [
        {
          "name": "Get Employees",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/employee?workspace_id=1",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"],
              "query": [
                { "key": "workspace_id", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Create Employee (Form Data)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/employee/create",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "create"]
            }
          }
        },
        {
          "name": "Store Employee",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"9876543210\",\n  \"gender\": \"male\",\n  \"dob\": \"1995-01-01\",\n  \"address\": \"New York\",\n  \"branch_id\": 1,\n  \"department_id\": 1,\n  \"designation_id\": 1,\n  \"role\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employee",
              "host": ["{{base_url}}"],
              "path": ["api", "employees"]
            }
          }
        },
        {
          "name": "Show Employee",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/employee/1",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "1"]
            }
          }
        },
        {
          "name": "Edit Employee",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/employee/1/edit",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "1", "edit"]
            }
          }
        },
        {
          "name": "Update Employee",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"phone\": \"9999999999\",\n  \"gender\": \"male\",\n  \"dob\": \"1995-01-01\",\n  \"address\": \"Updated Address\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/employee/1",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "1"]
            }
          }
        },
        {
          "name": "Delete Employee",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/employee/1",
              "host": ["{{base_url}}"],
              "path": ["api", "employees", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Dropdown APIs",
      "item": [
        {
          "name": "Get Departments by Branch",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{ \"branch_id\": 1 }"
            },
            "url": {
              "raw": "{{base_url}}/api/getdepartment",
              "host": ["{{base_url}}"],
              "path": ["api", "getdepartment"]
            }
          }
        },
        {
