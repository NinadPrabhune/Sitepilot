{
  "info": {
    "name": "Payments Module API",
    "_postman_id": "12345678-abcd-efgh-ijkl-987654321000",
    "description": "API collection for PaymentsModule with {{base_url}} and Bearer {{token}}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "List Payments",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/payments",
          "host": ["{{base_url}}"],
          "path": ["payments"]
        }
      }
    },
    {
      "name": "Create Data (Form Options)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"site_id\": 1,\n  \"workspace_id\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/payments/create-data",
          "host": ["{{base_url}}"],
          "path": ["payments", "create-data"]
        }
      }
    },
    {
      "name": "Store Payment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "created_by", "value": "1", "type": "text" },
            { "key": "workspace_id", "value": "1", "type": "text" },
            { "key": "supplier_id", "value": "1", "type": "text" },
            { "key": "purchase_invoice_id", "value": "", "type": "text" },
            { "key": "site_id", "value": "1", "type": "text" },
            { "key": "payment_date", "value": "2025-11-28", "type": "text" },
            { "key": "amount", "value": "1000", "type": "text" },
            { "key": "payment_type", "value": "against_invoice", "type": "text" },
            { "key": "mode", "value": "bank_transfer", "type": "text" },
            { "key": "reference_number", "value": "REF123", "type": "text" },
            { "key": "notes", "value": "Test payment", "type": "text" },
            { "key": "payment_proff_file", "type": "file" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/payments",
          "host": ["{{base_url}}"],
          "path": ["payments"]
        }
      }
    },
    {
      "name": "Show Payment",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/payments/1",
          "host": ["{{base_url}}"],
          "path": ["payments", "1"]
        }
      }
    },
    {
      "name": "Update Payment",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "created_by", "value": "1", "type": "text" },
            { "key": "workspace_id", "value": "1", "type": "text" },
            { "key": "supplier_id", "value": "1", "type": "text" },
            { "key": "site_id", "value": "1", "type": "text" },
            { "key": "payment_date", "value": "2025-11-28", "type": "text" },
            { "key": "amount", "value": "1500", "type": "text" },
            { "key": "payment_type", "value": "advance", "type": "text" },
            { "key": "notes", "value": "Updated payment", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/payments/1",
          "host": ["{{base_url}}"],
          "path": ["payments", "1"]
        }
      }
    },
    {
      "name": "Delete Payment",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/payments/1",
          "host": ["{{base_url}}"],
          "path": ["payments", "1"]
        }
      }
    }
  ]
}
