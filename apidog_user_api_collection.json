      "description": "POST /api/users - Create a new user",
      "method": "POST",
      "url": "{{base_url}}/api/users",
      "headers": {
        "Authorization": "Bearer {{token}}",
        "Content-Type": "multipart/form-data"
      },
      "params": {},
      "body": {
        "name": {"type": "text", "required": true, "description": "User name"},
        "email": {"type": "text", "required": true, "description": "User email"},
        "mobile_no": {"type": "text", "required": false, "description": "Mobile number (e.g., +1234567890)"},
        "password": {"type": "text", "required": false, "description": "Password (required if login enabled)"},
        "password_switch": {"type": "text", "required": false, "description": "'on' to enable login"},
        "roles": {"type": "text", "required": true, "description": "Role ID"},
        "avatar": {"type": "file", "required": false, "description": "Profile image file"},
        "workspace_id": {"type": "text", "required": false, "description": "Workspace ID"}
      },
      "response": {
        "success": {"status": true, "message": "User created successfully", "data": {"user": {"id": 1, "name": "John Doe", "email": "john@example.com"}}},
        "error": {"status": false, "message": "Validation error", "data": {"errors": {}}}
      }
    },
